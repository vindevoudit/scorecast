# scorecast-ml (training-only). Copy to .env and fill in if you want to
# override defaults. The trainer reads no env vars by default — these are
# all knobs for local dev convenience.
# Never commit .env (the root .gitignore covers ml/.env explicitly).

# pretty | json. Defaults to pretty when stderr is a TTY, JSON otherwise.
SCORECAST_LOG_FORMAT=

# Override the data + model artifact root. Defaults to ml/data/ relative
# to the package install location.
SCORECAST_DATA_ROOT=
