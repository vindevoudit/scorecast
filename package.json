{
  "name": "scorecast",
  "version": "0.1.0",
  "description": "Football prediction web app with groups, invites, and probability-based scoring.",
  "main": "server.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && node server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "test:unit": "node --test --test-reporter=spec tests/*.test.js",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --project=chromium --ui",
    "test:e2e:seed": "node tests/e2e/fixtures/seed.js",
    "test:screenshots": "playwright test --project=mobile-iphone-se --project=mobile-iphone-13 --project=mobile-pixel-5",
    "generate-pwa-assets": "node scripts/generate-pwa-assets.mjs",
    "assets:marketing": "node scripts/generate-marketing-assets.mjs"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@fontsource/orbitron": "^5.2.8",
    "@formkit/auto-animate": "^0.10.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/node": "^10.65.0",
    "@sentry/react": "^10.65.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "class-variance-authority": "^0.7.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "html-to-image": "^1.11.13",
    "jsonwebtoken": "^9.0.0",
    "motion": "^12.42.2",
    "node-cron": "^4.6.0",
    "obscenity": "^0.4.6",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.2",
    "resend": "^6.17.2",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.3",
    "uuid": "^11.1.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.40",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^5.4.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
