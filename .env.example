# Required in production — server will throw on startup if missing.
# In development, leaving this blank logs a warning and uses an insecure fallback.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Optional. If omitted, defaults to a local Postgres at localhost/scorecast_db (see db-config.js / models/index.js).
DATABASE_URL=

# Port the Express server listens on. Defaults to 3000.
PORT=3000

# 'development' or 'production'. Controls JWT_SECRET enforcement and Express error verbosity.
NODE_ENV=development

# Pino log level: 'fatal' | 'error' | 'warn' | 'info' | 'debug' | 'trace' | 'silent'.
# Defaults to 'debug' in development and 'info' in production.
LOG_LEVEL=

# In production, migrations do NOT auto-run on boot (you must run `npm run db:migrate`).
# Set this to 'true' to override and migrate on every server start. No effect in development.
MIGRATE_ON_BOOT=

# Sentry error tracking — server side. Leave blank to disable.
# When set, @sentry/node initializes at boot and Express errors are reported automatically.
SENTRY_DSN=

# Sentry error tracking — browser side. Read at Vite build time, so it must be prefixed VITE_.
# Leave blank to disable. When set, @sentry/react initializes on app start and
# render errors / unhandled exceptions are reported in addition to the local /api/client-errors log.
VITE_SENTRY_DSN=
