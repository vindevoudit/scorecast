# Allow CSV training corpus into git so Docker builds + onboarding work
# without re-downloading. Football-Data.co.uk data is public-domain. Block
# everything else under data/raw/ (no scratch files, no logs).
ml/data/raw/*
!ml/data/raw/*.csv
ml/data/elo/
ml/data/models/
ml/.env
ml/*.egg-info/
