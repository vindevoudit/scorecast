# Required in production — server will throw on startup if missing.
# In development, leaving this blank logs a warning and uses an insecure fallback.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Optional. If omitted, defaults to a local Postgres at localhost/scorecast_db (see db-config.js / models/index.js).
DATABASE_URL=

# Port the Express server listens on. Defaults to 3000.
PORT=3000

# 'development' or 'production'. Controls JWT_SECRET enforcement and Express error verbosity.
NODE_ENV=development

# Comma-separated allowlist of origins that may call the API with credentials.
# Required in production — server throws on boot when empty + NODE_ENV=production.
# In development, leaving this blank falls back to permissive `origin: true` so the Vite dev server works.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Pino log level: 'fatal' | 'error' | 'warn' | 'info' | 'debug' | 'trace' | 'silent'.
# Defaults to 'debug' in development and 'info' in production.
LOG_LEVEL=

# In production, migrations do NOT auto-run on boot (you must run `npm run db:migrate`).
# Set this to 'true' to override and migrate on every server start. No effect in development.
MIGRATE_ON_BOOT=

# Sentry error tracking — server side. Leave blank to disable.
# When set, @sentry/node initializes at boot and Express errors are reported automatically.
SENTRY_DSN=

# Sentry error tracking — browser side. Read at Vite build time, so it must be prefixed VITE_.
# Leave blank to disable. When set, @sentry/react initializes on app start and
# render errors / unhandled exceptions are reported in addition to the local /api/client-errors log.
VITE_SENTRY_DSN=

# Resend API key — outbound email transport for verification + password reset.
# Leave blank in development to use log-only mode: emails are rendered to stdout
# (copy the verify/reset link from the server log to test).
RESEND_API_KEY=

# Friendly From: address for outbound mail. Defaults to Resend's sandbox sender if unset.
EMAIL_FROM=

# Public base URL used to build verify/reset links in outgoing emails.
# In dev this is the Vite dev server. In prod this is the deployed site.
PUBLIC_APP_URL=http://localhost:5173

# Tier 4b / Tier 18 — football-data.org v4 API key. Free tier: 10 req/min.
# Production runs TIER_ONE at 20 req/min (live since 2026-05-23). Without a
# key, admin sync calls return 503 and the cron jobs silently no-op.
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_API_HOST=api.football-data.org

# Tier 18 — rate-limit headroom override. Defaults to 20 (TIER_ONE plan).
# Drop to 10 if you fall back to the free tier; bump if you upgrade further.
# The client always reserves 1 slot for ad-hoc admin syncs.
FOOTBALL_DATA_RATE_LIMIT=

# Tier 18 — live-score poll cadence. Defaults to every 30 s (node-cron 6-field).
# At 20 req/min budget this is ~2 req/min steady state. Drop to '* * * * *'
# (1 min) if you fall back to the free tier.
LIVE_SCORE_SYNC_CRON=

# Tier 18 — defensive reconcile cadence. Defaults to every 3 min. Sweeps
# in-progress games via ?ids= to catch upstream ?status= filter staleness.
IN_PROGRESS_RECONCILE_CRON=

# Tier 19 Chunk 5 — kickoff-time pick-scoring-lock cadence. Defaults to every
# 1 min. Cost-gated by a count() short-circuit, so off-season ticks are
# near-free. Don't slow this down — wide gaps between ticks lengthen the
# window where a late pick can land at moved odds before the lock fires.
LOCK_PICK_PROBABILITIES_CRON=

# Tier 30 Phase 3 A5 — weekly recap dispatch cadence. Defaults to '0 2 * * 1'
# (Mondays at 02:00 UTC). Cost-gated by a count() short-circuit on
# scored-picks-this-week so off-season runs are near-free. Push fires once
# per user with at least one pick scored in the trailing 7-day window.
WEEKLY_RECAP_CRON=

# Tier 31 — Matchday graphics automation. When MARKETING_AUTOMATION_ENABLED is
# '1' (or 'true'), the app registers a cron job that renders the right social
# graphic per fixture at the right moment (countdown ~2h before kickoff,
# fans-vs-model ~10m before, halftime at the break, fulltime at FT) and EMAILS
# the PNGs to MARKETING_EMAIL_TO so you just download + post. Reuses the Resend
# transport (RESEND_API_KEY + EMAIL_FROM above) — without a key it renders +
# logs in dev log-mode. Leave the gate unset to disable entirely (default).
MARKETING_AUTOMATION_ENABLED=
# Recipient for the matchday graphics emails (your inbox). Required for the job
# to actually send; the job no-ops with a warn if unset.
MARKETING_EMAIL_TO=
# Optional cron override for the matchday job. Defaults to '*/5 * * * *'
# (every 5 min). The countdown band is exactly one 5-min tick wide, so don't
# slow this below 5 min or countdown graphics will be missed.
MARKETING_GRAPHICS_CRON=

# PWA Chunk 4 — VAPID (Voluntary Application Server Identification) keys for
# Web Push. Generate with: npx web-push generate-vapid-keys
# Without all three set, PushService logs a warn at boot and every sendToUser
# call no-ops — the app keeps working, just without push delivery.
#  - PUBLIC key is sent to browsers via GET /api/push/vapid-public-key
#  - PRIVATE key is the signing secret; treat like JWT_SECRET (Key Vault in prod)
#  - SUBJECT is a `mailto:` URL — push services use it for abuse reports
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:vindevoudit@gmail.com
