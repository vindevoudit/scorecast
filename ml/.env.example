# scorecast-ml runtime config. Copy to .env and fill in real values.
# Never commit .env (the root .gitignore covers ml/.env explicitly).

# --- HTTP writer auth ---
# Credentials for the ml_pipeline service-account admin user (provisioned in
# the running app via UserManager UI). Used by db/writer.py to log into the
# ScoreCast HTTP API and post probability updates via PUT /api/admin/games/:id.
SCORECAST_ML_USERNAME=ml_pipeline
SCORECAST_ML_PASSWORD=

# Base URL of the running ScoreCast app (no trailing slash). Local dev:
# http://localhost:3000. Prod: https://bantryx.com.
SCORECAST_API_BASE_URL=http://localhost:3000

# --- DB reader (read-only queries: upcoming fixtures, league lookups) ---
# Same connection string the Node app uses. Local docker-compose Postgres
# omits sslmode; managed Azure DB for Postgres needs ?sslmode=require.
SCORECAST_DB_URL=postgres://scorecast:scorecast@localhost:5432/scorecast

# --- Optional ---
# pretty | json. Defaults to pretty when stderr is a TTY, JSON otherwise.
SCORECAST_LOG_FORMAT=
# Override the data + model artifact root. Defaults to ml/data/ relative to
# the package install location.
SCORECAST_DATA_ROOT=
